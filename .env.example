# Django Settings
DEBUG=True
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=sqlite:///db.sqlite3

# Google Maps & Distance APIs (Optional)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
USE_TRAFFIC_API=False

# GPS Simulation
SIMULATE_GPS=True
GPS_UPDATE_INTERVAL=5  # seconds

# WebSocket Settings
CHANNEL_LAYERS_BACKEND=channels.layers.InMemoryChannelLayer

# Security
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:8000

# Vehicle Defaults
DEFAULT_VEHICLE_SPEED=50  # km/h
DEFAULT_VEHICLE_CAPACITY=100

# Feature Flags
ENABLE_WEBSOCKETS=True
ENABLE_ANALYTICS=True
ENABLE_JWT_AUTH=False
